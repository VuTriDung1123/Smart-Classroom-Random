<Window x:Class="SmartClassroomRandom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Classroom Random" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E24">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2B2D35" CornerRadius="10" Padding="15,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="👥 Total " Foreground="#A0A0A5" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalStudents}" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>

                    <TextBlock Text="✅ Attend " Foreground="#A0A0A5" FontWeight="SemiBold"/>
                    <TextBlock Text="0" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>

                    <TextBlock Text="🚫 Banned " Foreground="#A0A0A5" FontWeight="SemiBold"/>
                    <TextBlock Text="0" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>

                    <TextBlock Text="🔍 Search" Foreground="#A0A0A5" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Choose " Foreground="#A0A0A5" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Width="150" Margin="0,0,15,0" SelectedIndex="0">
                    <ComboBoxItem Content="LTDD_CS03_THU7..."/>
                </ComboBox>

                <Button Content="Sync" Command="{Binding SyncExcelCommand}"
                        Background="#3B82F6" Foreground="White" FontWeight="Bold" 
                        Padding="20,8" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="#2B2D35" CornerRadius="12" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#4A90E2" CornerRadius="8" Padding="15,10" Width="180" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="🏆 Best" Foreground="White" FontSize="11" Opacity="0.8"/>
                            <TextBlock Text="Lê Thị Tuyết Băng" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,5,0,0"/>
                            <TextBlock Text="2" Foreground="White" FontSize="11" Opacity="0.8"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#E24A4A" CornerRadius="8" Padding="15,10" Width="180">
                        <StackPanel>
                            <TextBlock Text="💪 Try" Foreground="White" FontSize="11" Opacity="0.8"/>
                            <TextBlock Text="Updating..." Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,5,0,0"/>
                            <TextBlock Text="0" Foreground="White" FontSize="11" Opacity="0.8"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1E1E24" CornerRadius="8" Padding="15,10" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Number of students: " Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding GenerateCount}" Width="40" Background="Transparent" Foreground="White" 
                                     BorderThickness="0" TextAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Generate" Command="{Binding GenerateCommand}"
                            Foreground="White" FontWeight="Bold" FontSize="14"
                            Padding="30,10" BorderThickness="0" Cursor="Hand">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#B465DA" Offset="0.0" />
                                <GradientStop Color="#CF6CC9" Offset="0.5" />
                                <GradientStop Color="#EE609C" Offset="1.0" />
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding SelectedStudents}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="170" Height="220" Margin="0,0,15,15" CornerRadius="12" Padding="15">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4A90E2" Offset="0"/>
                                    <GradientStop Color="#2A5298" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding Name}" TextWrapping="Wrap" 
                                           FontSize="22" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>

                                <StackPanel Grid.Row="1">
                                    <Grid Margin="0,2">
                                        <TextBlock Text="Phát biểu:" Foreground="#D0D0D0" FontSize="11" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding PhatBieu}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <TextBlock Text="Không trả lời được:" Foreground="#D0D0D0" FontSize="11" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding KhongTraLoiDuoc}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <TextBlock Text="Không đi học:" Foreground="#D0D0D0" FontSize="11" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding KhongDiHoc}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <TextBlock Text="Ghi chú:" Foreground="#D0D0D0" FontSize="11" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding GhiChu}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>