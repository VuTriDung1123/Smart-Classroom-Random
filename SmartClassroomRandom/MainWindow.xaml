<Window x:Class="SmartClassroomRandom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Smart Classroom Random" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF0F5" Offset="0.0" />
            <GradientStop Color="#FFD1DC" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Color="Gray" Opacity="0.2"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="📥 Import Excel" Command="{Binding ImportCommand}"
                        Padding="15,10" Background="#FF69B4" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Sĩ số:" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock Text="{Binding Students.Count}" FontSize="16" FontWeight="Bold" Foreground="#FF69B4" Margin="5,0,20,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Số lượng:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBox Text="{Binding RandomCount}" Width="50" TextAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,15,0"/>

                    <Button Content="🎲 Random 1" Command="{Binding RandomOneCommand}" 
                            Padding="15,10" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="🎯 Random N" Command="{Binding RandomMultipleCommand}" 
                            Padding="15,10" Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Students}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Height="110" Margin="10" CornerRadius="12" Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Gray" Opacity="0.15"/>
                            </Border.Effect>

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="#FFB7C5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid Padding="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding Id, StringFormat='#{0}'}" 
                                           FontSize="12" Foreground="Gray" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="1" Text="{Binding Name}" TextWrapping="Wrap" 
                                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" TextAlignment="Center"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🗣️: " FontSize="12"/>
                                    <TextBlock Text="{Binding SpeakCount}" FontSize="12" FontWeight="Bold" Margin="0,0,10,0"/>
                                    <TextBlock Text="❌: " FontSize="12"/>
                                    <TextBlock Text="{Binding AbsenceCount}" FontSize="12" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>