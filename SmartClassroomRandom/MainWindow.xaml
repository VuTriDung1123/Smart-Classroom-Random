<Window x:Class="SmartClassroomRandom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Classroom Random" Height="768" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E24">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2B2D35" CornerRadius="0,20,20,0">
            <Grid Margin="0,20,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,10,20,40">
                    <TextBlock Text="Smart Classroom" Foreground="White" FontSize="22" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="Randomizer" Foreground="#B465DA" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="10,0">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton">
                            <Setter Property="Margin" Value="0,5"/>
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="Foreground" Value="#A0A0A5"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}" Cursor="Hand">
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#3B82F6"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Resources>

                    <RadioButton Content="📋 Xem danh sách lớp" Command="{Binding NavigateExcelCommand}" IsChecked="True"/>
                    <RadioButton Content="🎲 Random 1 người" Command="{Binding NavigateRandomOneCommand}"/>
                    <RadioButton Content="🎯 Random N người" Command="{Binding NavigateRandomNCommand}"/>
                    <RadioButton Content="📅 Xếp lịch báo cáo" Command="{Binding NavigateGroupCommand}"/>
                </StackPanel>

                <Border Grid.Row="2" Margin="20,0" Background="#1E1E24" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Dữ liệu hiện tại:" Foreground="#A0A0A5" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding CurrentFileName, FallbackValue='Chưa tải file'}" Foreground="White" FontWeight="Bold" Margin="0,0,0,15" TextTrimming="CharacterEllipsis"/>

                        <Button Content="📥 Tải Excel" Command="{Binding SyncExcelCommand}"
                                Background="#EE609C" Foreground="White" FontWeight="Bold" 
                                Padding="0,10" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="20">
            <ContentControl Content="{Binding CurrentView}" />
        </Border>

    </Grid>
</Window>