<Window x:Class="SmartClassroomRandom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Classroom Randomizer" Height="768" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E24">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= KHU VỰC SIDEBAR MENU (CỘT TRÁI) ================= -->
        <Border Grid.Column="0" Background="#2B2D35" CornerRadius="0,20,20,0">
            <Grid Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Logo / Tiêu đề -->
                    <RowDefinition Height="*"/>
                    <!-- Các tính năng (Có thể cuộn) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Nút Hướng dẫn (Dính dưới đáy) -->
                </Grid.RowDefinitions>

                <!-- Dùng chung Style cho toàn bộ RadioButton trong Sidebar -->
                <Grid.Resources>
                    <Style TargetType="RadioButton">
                        <Setter Property="Margin" Value="0,5"/>
                        <Setter Property="Padding" Value="15,12"/>
                        <Setter Property="Foreground" Value="#A0A0A5"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>

                <!-- TIÊU ĐỀ -->
                <StackPanel Grid.Row="0" Margin="20,10,20,30">
                    <TextBlock Text="Smart Classroom" Foreground="White" FontSize="22" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="Randomizer" Foreground="#B465DA" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- DANH SÁCH TÍNH NĂNG CHÍNH -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,0">
                        <RadioButton Content="📋 Xem danh sách lớp" Command="{Binding NavigateExcelCommand}" IsChecked="True"/>
                        <RadioButton Content="🎲 Random 1 người" Command="{Binding NavigateRandomOneCommand}"/>
                        <RadioButton Content="🎯 Random N người" Command="{Binding NavigateRandomNCommand}"/>
                        <RadioButton Content="📅 Xếp lịch báo cáo" Command="{Binding NavigateGroupCommand}"/>
                        <RadioButton Content="💣 Defuse The Bomb" Command="{Binding NavigateBombCommand}"/>
                        <RadioButton Content="🃏 Ma trận Lật thẻ" Command="{Binding NavigateMatrixCommand}"/>
                        <RadioButton Content="⚙️ Cài đặt chung" Command="{Binding NavigateSettingsCommand}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- NÚT HƯỚNG DẪN Ở ĐÁY -->
                <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#32343E" Margin="10,10,10,20" Padding="0,10,0,0">
                    <RadioButton Content="ℹ️ Hướng dẫn &amp; Thông tin" Command="{Binding NavigateGuideCommand}" Foreground="#FFD700"/>
                </Border>
            </Grid>
        </Border>

        <!-- ================= KHU VỰC HIỂN THỊ CHÍNH (CỘT PHẢI) ================= -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- THANH TOP BAR -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#2B2D35" CornerRadius="10" Padding="15,10" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="👥 Total " Foreground="#A0A0A5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalStudents}" Foreground="White" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <Rectangle Width="1" Height="20" Fill="#404040" Margin="0,0,15,0"/>
                            <TextBlock Text="🗣️ Gọi:" Foreground="#A0A0A5" FontWeight="SemiBold" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AudienceList}" SelectedItem="{Binding SelectedAudience}" Width="90" Margin="0,0,10,0" Foreground="Black" BorderThickness="0"/>
                            <ComboBox ItemsSource="{Binding ActionList}" SelectedItem="{Binding SelectedAction}" Width="180" Foreground="Black" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFD700" CornerRadius="10" Padding="15,10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#FFD700" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🏆 Best: " Foreground="#1E1E24" FontWeight="Bold"/>
                            <TextBlock Text="{Binding BestStudentName}" Foreground="#1E1E24" FontWeight="Bold" MaxWidth="100" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding BestStudentPoints, StringFormat=' ({0} đ)'}" Foreground="#1E1E24" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="File hiện tại:" Foreground="#A0A0A5" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>

                    <Border Background="#1E1E24" BorderBrush="#3B82F6" BorderThickness="1" 
                            CornerRadius="6" Padding="15,8" Margin="0,0,15,0" MinWidth="150" MaxWidth="250">
                        <TextBlock Text="{Binding CurrentFileName}" Foreground="White" FontWeight="Bold" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentFileName}"/>
                    </Border>

                    <Button Content="Sync" Command="{Binding SyncExcelCommand}"
                            Background="#3B82F6" Foreground="White" FontWeight="Bold" 
                            Padding="20,8" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- KHU VỰC HIỂN THỊ CÁC TRANG CON -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />

        </Grid>
    </Grid>
</Window>