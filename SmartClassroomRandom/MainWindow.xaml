<Window x:Class="SmartClassroomRandom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Classroom Random" Height="768" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E24">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2B2D35" CornerRadius="0,20,20,0">
            <Grid Margin="0,20,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,10,20,40">
                    <TextBlock Text="Smart Classroom" Foreground="White" FontSize="22" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="Randomizer" Foreground="#B465DA" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="10,0">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton">
                            <Setter Property="Margin" Value="0,5"/>
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="Foreground" Value="#A0A0A5"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}" Cursor="Hand">
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#3B82F6"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Resources>

                    <RadioButton Content="📋 Xem danh sách lớp" Command="{Binding NavigateExcelCommand}" IsChecked="True"/>
                    <RadioButton Content="🎲 Random 1 người" Command="{Binding NavigateRandomOneCommand}"/>
                    <RadioButton Content="🎯 Random N người" Command="{Binding NavigateRandomNCommand}"/>
                    <RadioButton Content="📅 Xếp lịch báo cáo" Command="{Binding NavigateGroupCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#2B2D35" CornerRadius="10" Padding="15,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="👥 Total " Foreground="#A0A0A5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalStudents}" Foreground="White" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>

                        <Rectangle Width="1" Height="20" Fill="#404040" Margin="0,0,15,0"/>

                        <TextBlock Text="🗣️ Gọi:" Foreground="#A0A0A5" FontWeight="SemiBold" Margin="0,0,5,0" VerticalAlignment="Center"/>

                        <ComboBox ItemsSource="{Binding AudienceList}" SelectedItem="{Binding SelectedAudience}" 
                                  Width="90" Margin="0,0,10,0" Foreground="Black" BorderThickness="0">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>

                        <ComboBox ItemsSource="{Binding ActionList}" SelectedItem="{Binding SelectedAction}" 
                                  Width="180" Foreground="Black" BorderThickness="0">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="File hiện tại:" Foreground="#A0A0A5" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>

                    <Border Background="#1E1E24" BorderBrush="#3B82F6" BorderThickness="1" 
                            CornerRadius="6" Padding="15,8" Margin="0,0,15,0" MinWidth="150" MaxWidth="250">
                        <TextBlock Text="{Binding CurrentFileName}" Foreground="White" FontWeight="Bold" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentFileName}"/>
                    </Border>

                    <Button Content="Sync" Command="{Binding SyncExcelCommand}"
                            Background="#3B82F6" Foreground="White" FontWeight="Bold" 
                            Padding="20,8" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />

        </Grid>
    </Grid>
</Window>