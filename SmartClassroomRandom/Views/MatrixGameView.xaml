<UserControl x:Class="SmartClassroomRandom.Views.MatrixGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2B2D35" CornerRadius="12" Padding="20,15" Margin="0,0,0,10">
            <Grid>
                <TextBlock Text="🃏 MA TRẬN LẬT THẺ NHÂN PHẨM" Foreground="#FFD700" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="🎲 TRỘN BÀI MỚI" Command="{Binding SetupMatrixCommand}"
                        HorizontalAlignment="Right" Background="#4A90E2" Foreground="White" FontWeight="Bold" Padding="30,10" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding MatrixCards}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding MatrixCols}" Rows="{Binding MatrixRows}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="8" Width="130" Height="130" Cursor="Hand"
                            Command="{Binding DataContext.FlipMatrixCardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="CardContainer" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Grid.RenderTransform>

                                    <Border x:Name="CardBack" Background="#2B2D35" CornerRadius="12" BorderThickness="3" BorderBrush="#404040">
                                        <TextBlock Text="{Binding CardNumber}" Foreground="#A0A0A5" FontSize="50" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border x:Name="CardFront" Visibility="Hidden" Background="{Binding CardColor}" CornerRadius="12" BorderThickness="3" BorderBrush="{Binding CardColor}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="{Binding CardColor}" Opacity="0.5"/>
                                        </Border.Effect>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                            <StackPanel.RenderTransform>
                                                <ScaleTransform ScaleX="-1"/>
                                            </StackPanel.RenderTransform>
                                            <TextBlock Text="{Binding CardIcon}" FontSize="45" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding CardTitle}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                            <Condition Binding="{Binding IsFlipped}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="CardBack" Property="Background" Value="#32343E"/>
                                        <Setter TargetName="CardBack" Property="BorderBrush" Value="#4A90E2"/>
                                    </MultiDataTrigger>

                                    <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="CardContainer" 
                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                                     From="1" To="0" Duration="0:0:0.15" />

                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CardBack" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Hidden}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CardFront" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>

                                                    <DoubleAnimation Storyboard.TargetName="CardContainer" 
                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                                     From="0" To="-1" BeginTime="0:0:0.15" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="2" Background="#1E1E24" CornerRadius="12" Padding="20,15" Margin="20,0,20,20" BorderThickness="1" BorderBrush="#32343E">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="❓" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Câu hỏi" Foreground="#4A90E2" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding MatrixDescNormal}" Foreground="#A0A0A5" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="🛡️" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="An toàn" Foreground="#2ECC40" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding MatrixDescSafe}" Foreground="#A0A0A5" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="⭐" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="+1 Điểm" Foreground="#FFD700" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding MatrixDescBonus}" Foreground="#A0A0A5" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💣" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bom tử thần" Foreground="#FF4136" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding MatrixDescBomb}" Foreground="#A0A0A5" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </WrapPanel>
        </Border>

    </Grid>
</UserControl>