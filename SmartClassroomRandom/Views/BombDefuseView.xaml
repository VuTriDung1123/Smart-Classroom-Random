<UserControl x:Class="SmartClassroomRandom.Views.BombDefuseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2B2D35" CornerRadius="12" Padding="20,15" Margin="0,0,0,20">
            <Grid>
                <TextBlock Text="💣 THỬ THÁCH CẮT DÂY BOM" Foreground="#FF4136" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="TẠO BOM MỚI" Command="{Binding SetupBombCommand}"
                        HorizontalAlignment="Right" Background="#FF4136" Foreground="White" FontWeight="Bold" Padding="30,10" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </TextBlock.RenderTransform>
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="💣"/>
                        <Setter Property="FontSize" Value="120"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBombExploded}" Value="False">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="PulseAnim">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.5" Duration="0:0:0.6" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="PulseAnim"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBombExploded}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding BombWires}" HorizontalAlignment="Center" Margin="0,0,0,40">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="150" Height="200" Margin="10,0" CornerRadius="12" Padding="15" Background="#1E1E24" BorderThickness="4" BorderBrush="{Binding WireColor}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{Binding WireColor}" CornerRadius="6" Padding="8">
                                    <TextBlock Text="{Binding WireName}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>

                                <Rectangle Grid.Row="1" Width="15" Fill="{Binding WireColor}" Margin="0,15"/>

                                <Button Grid.Row="2" Content="✂️ CẮT DÂY" FontSize="16" FontWeight="Bold" Padding="10" Cursor="Hand"
                                        Command="{Binding DataContext.CutWireCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#32343E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCut}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <TextBlock Grid.Row="2" Text="✅ AN TOÀN" Foreground="#2ECC40" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSafe}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.RowSpan="2" Visibility="Collapsed" CornerRadius="15">
                <Border.Background>
                    <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#EEFFD700" Offset="0.0"/>
                        <GradientStop Color="#EEFF4500" Offset="0.3"/>
                        <GradientStop Color="#EE8B0000" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBombExploded}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="💥" FontSize="150" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0" To="1.2" Duration="0:0:0.5">
                                                    <DoubleAnimation.EasingFunction>
                                                        <ElasticEase Oscillations="1" Springiness="4" EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0" To="1.2" Duration="0:0:0.5">
                                                    <DoubleAnimation.EasingFunction>
                                                        <ElasticEase Oscillations="1" Springiness="4" EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="RẤT TIẾC!" Foreground="White" FontSize="60" FontWeight="Black" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="4" Color="Black" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="LÊN BẢNG TRẢ BÀI NGAY" Foreground="White" FontSize="50" FontWeight="Black" HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="4" Color="Black" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Button Content="🔄 CHƠI LẠI VÁN MỚI" Command="{Binding SetupBombCommand}"
                            Margin="0,30,0,0" Padding="30,15" FontSize="20" FontWeight="Bold" Cursor="Hand"
                            Background="White" Foreground="#8B0000" BorderThickness="0" HorizontalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>