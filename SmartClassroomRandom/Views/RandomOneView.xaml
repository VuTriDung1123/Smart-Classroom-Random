<UserControl x:Class="SmartClassroomRandom.Views.RandomOneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="🎲 GỌI BÀI NGẪU NHIÊN" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Cơ chế công bằng: Ưu tiên sinh viên ít phát biểu" Foreground="#A0A0A5" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Width="400" Height="300" CornerRadius="20" Padding="30" 
                DataContext="{Binding SelectedSingleStudent}" VerticalAlignment="Center" HorizontalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Color="Black" Opacity="0.5"/>
            </Border.Effect>

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A90E2" Offset="0"/>
                    <GradientStop Color="#2A5298" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Name}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Hidden"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Name}" Value="">
                                <Setter Property="Visibility" Value="Hidden"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding Id, StringFormat='Mã số: {0}'}" 
                           Foreground="#D0D0D0" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="1" Text="{Binding Name}" TextWrapping="Wrap" 
                           FontSize="40" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>

                <Border Grid.Row="2" Background="#1E1E24" Opacity="0.8" CornerRadius="10" Padding="15">
                    <UniformGrid Columns="3">
                        <StackPanel>
                            <TextBlock Text="Phát biểu" Foreground="#A0A0A5" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PhatBieu}" Foreground="#4CAF50" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Không TL" Foreground="#A0A0A5" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding KhongTraLoiDuoc}" Foreground="#FF9800" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Vắng" Foreground="#A0A0A5" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding KhongDiHoc}" Foreground="#F44336" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="SẴN SÀNG!" Foreground="#404040" FontSize="50" FontWeight="Bold" 
                   HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedSingleStudent}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Button Grid.Row="2" Command="{Binding RandomOneCommand}"
                HorizontalAlignment="Center" Margin="0,30,0,0" Padding="50,20" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="15" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF416C" Offset="0"/>
                    <GradientStop Color="#FF4B2B" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎲" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="QUAY SỐ" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>